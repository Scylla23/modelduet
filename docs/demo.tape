Output docs/demo.gif

Require bash

Set Shell "bash"
Set Width 880
Set Height 520
Set FontSize 15
Set FontFamily "Menlo"
Set LetterSpacing 0
Set LineHeight 1.1
Set Theme "TokyoNight"
Set Padding 24
Set Framerate 12
Set PlaybackSpeed 1
Set WindowBar Colorful
Set WindowBarSize 36
Set TypingSpeed 25ms

Type "bash docs/demo.sh"
Enter
Sleep 24s
